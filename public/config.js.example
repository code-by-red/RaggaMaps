    // Google Apps Script URL - Replace with your actual Web App URL
    APP_SCRIPT_URL: 'YOUR_APPS_SCRIPT_URL_HERE',
    
    // Google Sheets Configuration
    GOOGLE_SHEETS: {
        SPREADSHEET_ID: 'YOUR_SPREADSHEET_ID',
